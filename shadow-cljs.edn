{:http {:port 9633},
 :source-paths ["src/cljs" "src/clj" "src/gen" ".ημ" "test/cljs"
                "../katamorph/src/cljs"
                "../event-ledger/src"],
 :dependencies
 [[cider/cider-nrepl "0.50.2"]
  [refactor-nrepl "3.9.1"]
  [metosin/malli "0.16.4"]
  [funcool/promesa "11.0.678"]],
 :nrepl {:port 4501},
 :js-options {:js-provider :import},
 :builds
 {:app
  {:target :esm,
   :output-dir "dist",
   :modules
   {:app
     {:exports
      {:solPlugin open-hax.sol.plugin/sol-plugin,
       :config open-hax.sol.infra.config/config-js,
       :bootstrap open-hax.sol.bootstrap/bootstrap!,
       :start open-hax.sol.infra.core/start!,
       :registerAppRoutes open-hax.sol.infra.core/register-app-routes!,
       :registerWsRoutes open-hax.sol.infra.core/register-ws-routes!}}},
   :js-options
   {:js-provider :import,
    :keep-as-import
     #{"node:fs/promises"
       "node:fs"
       "node:path"
       "node:url"
       "@open-hax/eta-mu-cli"
       "@modelcontextprotocol/sdk/client/index.js"
       "@modelcontextprotocol/sdk/client/streamableHttp.js"
       "typebox"
       "fastify"
       "ws"}},
    :compiler-options
    {:output-feature-set :es-next,
     :optimizations :simple,
     :source-map true,
     :infer-externs false,
     :macros {:open-hax.sol.macros true},
     :warnings {:infer-warning false}}},
  :server-dev
  {:target :esm,
   :runtime :node,
   :output-dir "dist-dev",
   :modules {:server {:init-fn open-hax.sol.entrypoint/init}},
   :js-options
   {:js-provider :import,
    :keep-as-import
     #{"node:fs/promises"
       "node:fs"
       "node:path"
       "node:url"
       "@open-hax/eta-mu-cli"
       "@modelcontextprotocol/sdk/client/index.js"
       "@modelcontextprotocol/sdk/client/streamableHttp.js"
       "typebox"
       "fastify"
       "ws"}},
    :devtools
    {:autoload true,
     :preloads [shadow.cljs.devtools.client.node-esm],
     :ignore-warnings true,
     :before-load-async open-hax.sol.bootstrap/stop-http-before-load!,
     :after-load-async open-hax.sol.bootstrap/start-http-after-load!},
   :compiler-options
   {:output-feature-set :es-next,
    :optimizations :none,
    :source-map true,
    :infer-externs false,
    :macros {:open-hax.sol.macros true},
    :warnings {:infer-warning false}}},
  :server
  {:target :esm,
   :runtime :node,
   :output-dir "dist",
   :modules {:server {:init-fn open-hax.sol.entrypoint/init}},
   :js-options
   {:js-provider :import,
    :keep-as-import
     #{"node:fs/promises"
       "node:fs"
       "node:path"
       "node:url"
       "@open-hax/eta-mu-cli"
       "@modelcontextprotocol/sdk/client/index.js"
       "@modelcontextprotocol/sdk/client/streamableHttp.js"
       "typebox"
       "fastify"
       "ws"}},
    :compiler-options
    {:output-feature-set :es-next,
     :optimizations :none,
     :source-map true,
     :infer-externs false,
     :macros {:open-hax.sol.macros true},
     :warnings {:infer-warning false}}},
   :test
   {:target :node-test,
    :output-to "target/test/test.cjs",
     :ns-regexp "(open-hax\\.sol\\..*-test$|eta-mu\\..*-test$)",
    :autorun true,
    :js-options {:resolve {"@open-hax/eta-mu-cli" {:target :file
                                                       :file "test/js/eta_mu_cli_test_stub.cjs"}}},
    :compiler-options
    {:output-feature-set :es-next,
     :macros {:open-hax.sol.macros true},
     :infer-externs false}},
    :daemon
    {:target :esm,
     :runtime :node,
     :output-dir "dist-daemon",
     :modules {:daemon {:init-fn eta-mu.daemon.core/init}},
     :build-hooks [(eta-mu.daemon.build/emit-package-json)],
     :js-options {:js-provider :import},
     :compiler-options
     {:output-feature-set :es-next,
      :optimizations :simple,
      :source-map false,
      :infer-externs false,
      :warnings {:infer-warning false}}},
    :opencode-plugin
    {:target :esm,
     :runtime :node,
     :output-dir ".opencode/dist",
     :modules
     {:eta-mu-actors
      {:exports
       {:EtaMuActorsPlugin eta-mu.gen.opencode-plugin/plugin}}},
     :build-hooks [(eta-mu.opencode.build/generate-entrypoint)
                   (eta-mu.opencode.build/emit-host-config)],
     :js-options
     {:js-provider :import,
      :keep-as-import #{"zod"}},
     :compiler-options
     {:output-feature-set :es-next,
      :optimizations :simple,
      :source-map false,
      :infer-externs false,
      :warnings {:infer-warning false}}}}}
